# Plantilla de variables de entorno.
# Copia este archivo como ".env.local" y completa los valores reales.
# El archivo .env.local NO se sube al repositorio (ver .gitignore).

# Usuario administrador del sitio
TT_ADMIN_USER=admin

# Contraseña del administrador
TT_ADMIN_PASS=tu-contraseña-aqui

# Clave secreta para firmar la cookie de sesión.
# Genera una cadena aleatoria larga, por ejemplo con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
TT_AUTH_SECRET=cadena-aleatoria-larga-y-secreta
